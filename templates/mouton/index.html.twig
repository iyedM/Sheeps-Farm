{% extends 'base.html.twig' %}

{% block title %}Moutons - FermeApp{% endblock %}

{% block breadcrumb_current %}Moutons{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Moutons</h1>
        <p class="page-subtitle">Gestion de votre cheptel</p>
    </div>
    <div class="page-actions">
        <button class="btn-secondary">
            <i class="bi bi-download"></i> Exporter
        </button>
        <a href="{{ path('app_mouton_group_new') }}" class="btn-secondary">
            <i class="bi bi-collection"></i> Groupe
        </a>
        <a href="{{ path('app_mouton_vaccin_bulk') }}" class="btn-secondary">
            <i class="bi bi-shield-plus"></i> Vaccin groupe
        </a>
        <a href="{{ path('app_mouton_new') }}" class="btn-primary">
            <i class="bi bi-plus-lg"></i> Nouveau
        </a>
    </div>
</div>

<div class="filter-bar" data-aos="fade-down" data-aos-delay="100">
    <button class="filter-toggle" data-bs-toggle="collapse" data-bs-target="#filterPanel">
        <i class="bi bi-sliders"></i> Filtres
        {% if filters.race or filters.genre or filters.origine %}
            <span class="filter-count-badge">!</span>
        {% endif %}
        <i class="bi bi-chevron-down filter-arrow"></i>
    </button>
    <div class="collapse {% if filters.race or filters.genre or filters.origine %}show{% endif %}" id="filterPanel">
        <div class="filter-panel">
            <form method="get">
                <div class="filter-grid">
                    <input name="race" value="{{ filters.race }}" placeholder="Race" class="form-control">
                    
                    <select name="genre" class="form-select">
                        <option value="">-- Tous les genres --</option>
                        <option value="Mâle" {% if filters.genre == 'Mâle' %}selected{% endif %}>Mâle</option>
                        <option value="Femelle" {% if filters.genre == 'Femelle' %}selected{% endif %}>Femelle</option>
                    </select>

                    <select name="origine" class="form-select">
                        <option value="">-- Toutes les origines --</option>
                        <option value="Interne" {% if filters.origine == 'Interne' %}selected{% endif %}>Interne</option>
                        <option value="Externe" {% if filters.origine == 'Externe' %}selected{% endif %}>Externe</option>
                    </select>
                </div>
                <div class="filter-actions">
                    <a href="{{ path('app_mouton_index') }}" class="btn-secondary btn-sm" id="resetFilters">
                        <i class="bi bi-x-lg"></i> Réinitialiser
                    </a>
                    <button class="btn-primary btn-sm" type="submit">
                        <i class="bi bi-search"></i> Appliquer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="200">
    <div class="table-card-header">
        <div>
            <h3>Liste des Moutons</h3>
            <span class="record-count">{{ pagination.getTotalItemCount() }} résultats</span>
        </div>
        <div class="table-actions">
            <!-- DataTables search integration or manual search input -->
            <div class="search-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Rechercher (page)..." class="table-search" id="tableSearch"/>
            </div>
        </div>
    </div>

    <!-- DataTables will handle the presentation gracefully without rendering double paginators -->
    <div class="table-responsive">
        <table class="table dt-table dt-server" width="100%">
            <thead>
                <tr>
                    <th>N° Identification</th>
                    <th>Race</th>
                    <th>Genre</th>
                    <th>Âge & Poids</th>
                    <th>Santé</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for m in pagination %}
                <tr>
                    <td><strong>#{{ m.id }}</strong></td>
                    <td><span style="font-weight: 500;">{{ m.race }}</span></td>
                    <td>
                        {% if m.genre == 'Mâle' %}
                            <span class="badge-genre badge-male"><i class="bi bi-gender-male"></i> Mâle</span>
                        {% else %}
                            <span class="badge-genre badge-female"><i class="bi bi-gender-female"></i> Femelle</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge-status" style="background: var(--bg-hover); color: var(--text-secondary); border-radius: var(--radius-sm);"><i class="bi bi-calendar3 me-1"></i> {{ m.currentAge }} mois</span>
                    </td>
                    <td>
                        {% if m.vaccins|length > 0 %}
                            <span class="badge-status badge-success"><i class="bi bi-shield-check"></i> Vaccin: {{ m.vaccins|last.dateVaccination|date('d/m') }}</span>
                        {% else %}
                            <span class="badge-status badge-warning"><i class="bi bi-exclamation-triangle"></i> Aucun vaccin</span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <div class="row-actions justify-content-end">
                            <a href="{{ path('app_mouton_show', {id:m.id}) }}" class="action-btn action-view" title="Voir la fiche détaillée">
                                <i class="bi bi-eye-fill"></i>
                            </a>
                            <a href="{{ path('app_mouton_edit', {id:m.id}) }}" class="action-btn action-edit" title="Modifier">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="{{ path('app_mouton_delete', {id:m.id}) }}" class="d-inline" id="form-delete-mouton-{{ m.id }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_mouton_' ~ m.id) }}">
                                <button type="button" class="action-btn action-delete" title="Supprimer" onclick="confirmDelete('form-delete-mouton-{{ m.id }}', 'le mouton #{{ m.id }}')">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">Aucun mouton trouvé correspondant à vos critères.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div class="table-pagination-wrapper">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>
{% endblock %}
