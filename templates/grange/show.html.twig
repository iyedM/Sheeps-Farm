{% extends 'base.html.twig' %}
{% block page_title %}Grange {{ grange.nom }}{% endblock %}
{% block body %}
<div class="card"><div class="card-body">
<p><strong>Localisation:</strong> {{ grange.localisation }}</p>
<h5>Moutons</h5>
<ul>{% for mouton in grange.moutons %}<li>#{{ mouton.id }} - {{ mouton.race }} ({{ mouton.genre }})</li>{% else %}<li>Aucun mouton.</li>{% endfor %}</ul>
</div></div>
{% endblock %}
