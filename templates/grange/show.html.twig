{% extends 'base.html.twig' %}

{% block title %}Grange #{{ grange.id }} - FermeApp{% endblock %}
{% block breadcrumb_current %}Granges > Détails{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Grange: {{ grange.nom }}</h1>
        <p class="page-subtitle">Informations sur l'hébergement et les moutons assignés</p>
    </div>
    <div class="page-actions">
        <a href="{{ path('app_grange_index') }}" class="btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
        <a href="{{ path('app_grange_edit', {id: grange.id}) }}" class="btn-primary">
            <i class="bi bi-pencil"></i> Modifier
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-4 mb-4" data-aos="fade-right" data-aos-delay="100">
        <div class="form-card h-100">
            <div class="form-card-header">
                <h3><i class="bi bi-info-circle"></i> Aperçu</h3>
            </div>
            <div class="form-card-body">
                <div class="detail-group mb-4">
                    <label class="detail-label">Nom de la Grange</label>
                    <div class="detail-value fw-bold" style="font-size:18px;">{{ grange.nom }}</div>
                </div>
                <div class="detail-group mb-4">
                    <label class="detail-label">Localisation</label>
                    <div class="detail-value">
                        <span class="badge-status" style="background: var(--bg-hover); color: var(--text-secondary); border-radius: var(--radius-sm);">
                            <i class="bi bi-geo-alt me-1"></i> {{ grange.localisation }}
                        </span>
                    </div>
                </div>
                <div class="detail-group">
                    <label class="detail-label">Capacité Actuelle</label>
                    <div class="detail-value">
                        <h2 style="color:var(--accent); margin:0;">{{ grange.moutons|length }} moutons</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8 mb-4" data-aos="fade-left" data-aos-delay="200">
        <div class="table-card h-100">
            <div class="table-card-header">
                <div>
                    <h3>Moutons Résidents</h3>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table dt-table" width="100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Race</th>
                            <th>Genre</th>
                            <th class="text-end">Fiche</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for mouton in grange.moutons %}
                        <tr>
                            <td><strong>#{{ mouton.id }}</strong></td>
                            <td>{{ mouton.race }}</td>
                            <td>
                                {% if mouton.genre == 'Mâle' %}
                                    <span class="badge-genre badge-male"><i class="bi bi-gender-male"></i> Mâle</span>
                                {% else %}
                                    <span class="badge-genre badge-female"><i class="bi bi-gender-female"></i> Femelle</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('app_mouton_show', {id: mouton.id}) }}" class="action-btn action-view">
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Cette grange est actuellement vide.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
