{% extends 'base.html.twig' %}

{% block title %}Modifier Grange - FermeApp{% endblock %}
{% block breadcrumb_current %}Granges > Modifier{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Modifier Grange</h1>
        <p class="page-subtitle">Mettre à jour les informations de l'hébergement</p>
    </div>
    <div class="page-actions">
        <a href="{{ path('app_grange_index') }}" class="btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour à la liste
        </a>
    </div>
</div>

<div class="row" data-aos="fade-up" data-aos-delay="100">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="bi bi-pencil-fill"></i> Édition de grange</h3>
                <p>Correction des détails de l'abri #{{ grange.id }}</p>
            </div>
            <div class="form-card-body">
                {{ form_start(form, {'attr': {'class': 'modern-form', 'novalidate': 'novalidate'}}) }}
                
                {% if not form.vars.valid %}
                    <div class="alert alert-danger" style="font-size:13px; border-radius:var(--radius-sm); border:none; background:var(--danger-light); color:var(--danger);">
                        {{ form_errors(form) }}
                    </div>
                {% endif %}

                <div class="row gx-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small mb-1">Nom de la Grange</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                        <div class="invalid-feedback d-block">{{ form_errors(form.nom) }}</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small mb-1">Localisation / Emplacement</label>
                        {{ form_widget(form.localisation, {'attr': {'class': 'form-control'}}) }}
                        <div class="invalid-feedback d-block">{{ form_errors(form.localisation) }}</div>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button class="btn-primary btn-submit" type="submit">
                        <i class="bi bi-check-lg"></i> Enregistrer les modifications
                        <div class="btn-spinner spinner-border text-light d-none" role="status" style="width: 16px; height: 16px;"></div>
                    </button>
                    <a href="{{ path('app_grange_index') }}" class="btn-secondary">Annuler</a>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
