{% extends 'base.html.twig' %}

{% block title %}Factures Achat - FermeApp{% endblock %}
{% block breadcrumb_current %}Factures > Achats{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Factures d'Achats</h1>
        <p class="page-subtitle">Gestion de la facturation avec vos fournisseurs</p>
    </div>
    <div class="page-actions">
        <a href="{{ path('app_facture_achat_new') }}" class="btn-primary">
            <i class="bi bi-receipt"></i> Nouvelle facture
        </a>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="100">
    <div class="table-card-header">
        <div>
            <h3>Registre des Factures</h3>
            <span class="record-count">{{ pagination.getTotalItemCount() }} résultats</span>
        </div>
        <div class="table-actions">
            <div class="search-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Rechercher (page)..." class="table-search" id="tableSearch"/>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table dt-table dt-server" width="100%">
            <thead>
                <tr>
                    <th>N° Facture</th>
                    <th>Fournisseur</th>
                    <th>Date d'Achat</th>
                    <th>Montant Total</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for f in pagination %}
                <tr>
                    <td><strong>FAC-A-{{ '%04d'|format(f.id) }}</strong></td>
                    <td><span style="font-weight: 500;">{{ f.fournisseur }}</span></td>
                    <td><span class="badge-status" style="background: var(--bg-hover); color: var(--text-secondary); border-radius: var(--radius-sm);"><i class="bi bi-calendar3 me-1"></i> {{ f.dateAchat|date('d/m/Y') }}</span></td>
                    <td><strong style="color: var(--accent);">{{ f.totalGlobal|number_format(2, '.', ' ') }}</strong> <span style="font-size:12px; color:var(--text-muted);">TND</span></td>
                    <td class="text-end">
                        <div class="row-actions justify-content-end">
                            <a href="{{ path('app_facture_achat_show', {id:f.id}) }}" class="action-btn action-view" title="Voir les détails">
                                <i class="bi bi-eye-fill"></i>
                            </a>
                            <a href="{{ path('app_facture_achat_pdf', {id:f.id}) }}" target="_blank" class="action-btn action-pdf" title="Télécharger le PDF" style="--btn-color: #ff4757; --btn-bg: rgba(255, 71, 87, 0.1); --btn-hover-bg: #ff4757; --btn-hover-color: white;">
                                <i class="bi bi-file-earmark-pdf-fill"></i>
                            </a>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">Aucune facture d'achat trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div class="table-pagination-wrapper">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>
{% endblock %}
