{% extends 'base.html.twig' %}

{% block title %}Ventes - FermeApp{% endblock %}
{% block breadcrumb_current %}Commerce > Ventes{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Ventes de Moutons</h1>
        <p class="page-subtitle">Suivi de vos transactions commerciales</p>
    </div>
    <div class="page-actions">
        <a href="{{ path('app_commerce_vente_new') }}" class="btn-primary">
            <i class="bi bi-cart-check"></i> Nouvelle vente
        </a>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="100">
    <div class="table-card-header">
        <div>
            <h3>Registre des Ventes</h3>
            <span class="record-count">{{ pagination.getTotalItemCount() }} résultats</span>
        </div>
        <div class="table-actions">
            <div class="search-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Rechercher (page)..." class="table-search" id="tableSearch"/>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table dt-table dt-server" width="100%">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Race</th>
                    <th>Quantité</th>
                    <th>Total</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for v in pagination %}
                <tr>
                    <td><span style="font-weight: 500;">{{ v.client }}</span></td>
                    <td>{{ v.race }}</td>
                    <td><span class="badge" style="background-color: #00d68f; color: white; border-radius: var(--radius-sm);">{{ v.quantite }}</span></td>
                    <td><strong style="color: #00d68f;">{{ v.prixTotal|number_format(2, '.', ' ') }}</strong> <span style="font-size:12px; color:var(--text-muted);">TND</span></td>
                    <td class="text-end">
                        <div class="row-actions justify-content-end">
                            <a href="{{ path('app_commerce_vente_edit', {id:v.id}) }}" class="action-btn action-edit" title="Modifier">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="{{ path('app_commerce_vente_delete', {id:v.id}) }}" class="d-inline" id="form-delete-vente-{{ v.id }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_vente_' ~ v.id) }}">
                                <button type="button" class="action-btn action-delete" title="Supprimer" onclick="confirmDelete('form-delete-vente-{{ v.id }}', 'cette vente')">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">Aucune vente enregistrée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div class="table-pagination-wrapper">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>
{% endblock %}
