{% extends 'base.html.twig' %}

{% block title %}Nouveau marché Aïd{% endblock %}
{% block breadcrumb_current %}Marketplace Aïd > {{ campagne.nom }} > Nouveau marché{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Nouveau marché</h1>
        <p class="page-subtitle">Créez un marché pour la campagne {{ campagne.nom }}.</p>
    </div>
    <div class="page-actions">
        <a href="{{ path('aid_campagne_show', {id: campagne.id}) }}" class="btn-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
    </div>
</div>

{% include 'aid/marches/_form.html.twig' with { form: form, campagne: campagne, button_label: 'Créer le marché' } %}
{% endblock %}
