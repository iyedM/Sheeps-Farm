{% extends 'base.html.twig' %}

{% block title %}Modifier {{ marche.nom }}{% endblock %}

{% block body %}
<div class="page-header mb-4">
    <div>
        <h1 class="h3 mb-1">Modifier le marché</h1>
        <p class="text-muted mb-0">Ajustez les lots, quantités et responsable.</p>
    </div>
    <a href="{{ path('aid_marche_show', {campagneId: campagne.id, id: marche.id}) }}" class="btn btn-outline-secondary">Retour</a>
</div>

{% include 'aid/marches/_form.html.twig' with { form: form, campagne: campagne, button_label: 'Enregistrer les modifications' } %}
{% endblock %}