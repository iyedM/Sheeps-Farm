{% extends 'base.html.twig' %}

{% block title %}Nouvelle campagne Aïd{% endblock %}

{% block body %}
<div class="page-header mb-4">
    <div>
        <h1 class="h3 mb-1">Nouvelle campagne Aïd</h1>
        <p class="text-muted mb-0">Définissez la campagne qui centralise vos ventes Aïd.</p>
    </div>
    <a href="{{ path('aid_campagne_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<div class="card dashboard-card">
    <div class="card-body">
        {{ form_start(form) }}
            <div class="row g-3">
                <div class="col-12 col-lg-8">{{ form_row(form.nom) }}</div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-primary">Créer</button>
                <a href="{{ path('aid_campagne_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
