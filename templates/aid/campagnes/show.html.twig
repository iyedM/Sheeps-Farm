{% extends 'base.html.twig' %}

{% block title %}{{ campagne.nom }} | Pilotage Stratégique{% endblock %}
{% block breadcrumb_current %}Marketplace Aïd > {{ campagne.nom }}{% endblock %}

{% block body %}
{% set percentVendu = campagne.stockInitial > 0 ? (campagne.moutonsVendus / campagne.stockInitial * 100) : 0 %}

{# Logique Leaderboard #}
{% set maxPercent = -1 %}
{% set leaderId = null %}
{% for marche in campagne.marches %}
    {% set p = marche.moutonsAmenes > 0 ? (marche.moutonsVendus / marche.moutonsAmenes * 100) : 0 %}
    {% if p > maxPercent %}
        {% set maxPercent = p %}
        {% set leaderId = marche.id %}
    {% endif %}
{% endfor %}

<div class="premium-surface">
    <!-- Panoramic Hero Strategic Board -->
    <div class="aid-hero-card mb-4" data-aos="fade-down" style="background: linear-gradient(135deg, #0D1426 0%, #1a253a 100%), radial-gradient(at 0% 0%, rgba(0, 214, 143, 0.15) 0px, transparent 50%); color: white; padding: 40px 48px; border-radius: 32px; box-shadow: 0 30px 60px -12px rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.08); position: relative; overflow: hidden; display: flex; flex-wrap: wrap; gap: 40px; align-items: flex-end;">
        <div class="hero-glow-blob" style="position: absolute; top: -50px; right: -50px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(0, 214, 143, 0.1) 0%, transparent 70%); pointer-events: none;"></div>
        
        <div class="aid-hero-main" style="flex: 2; min-width: 320px;">
            <div class="d-flex align-items-center gap-2 mb-2 opacity-50 font-xs ls-wide text-uppercase fw-800">
                <i class="bi bi-broadcast"></i> Console de Pilotage <span class="badge bg-success-soft text-success px-2 py-1 ms-2" style="font-size: 8px;">LIVE DATA</span>
            </div>
            <h1 class="mb-2" style="font-size: 3.5rem; font-weight: 850; letter-spacing: -0.05em; line-height: 0.9;">{{ campagne.nom }}</h1>
            <p class="mb-4 opacity-50 font-sm" style="max-width: 450px;">Analyse en temps réel des flux d'acquisition et de la performance des canaux de distribution.</p>

            <div class="hero-stock-console p-3 rounded-4" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(20px);">
                <div class="d-flex justify-content-between align-items-baseline mb-2">
                    <span class="text-white-50 font-xs fw-bold text-uppercase ls-tight">Ventes consolidées</span>
                    <span class="h5 text-white m-0 font-numeric fw-800">{{ campagne.moutonsVendus }}<small class="opacity-25 h6 ps-2">/{{ campagne.stockInitial }}</small></span>
                </div>
                <div class="hero-progress-track" style="height: 6px; background: rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden;">
                    <div class="hero-progress-fill" style="width:{{ percentVendu }}%; height: 100%; background: linear-gradient(90deg, #00D68F, #00A3FF); box-shadow: 0 0 15px rgba(0,214,143,0.3);"></div>
                </div>
            </div>
        </div>

        <div class="aid-hero-extra d-flex gap-5" style="flex: 1; justify-content: flex-end;">
            <div class="text-end">
                <div class="text-white-50 font-xs text-uppercase ls-wide mb-1">Impact Net</div>
                <div class="h2 m-0 fw-850 text-success">{{ (campagne.capitalNet/1000)|number_format(1) }}k <small class="h6">TND</small></div>
            </div>
            <div class="text-end">
                <div class="text-white-50 font-xs text-uppercase ls-wide mb-1">Conversion</div>
                <div class="h2 m-0 fw-850 text-primary">{{ percentVendu|round }}%</div>
            </div>
        </div>
    </div>

    <!-- Premium Strategic Navigation -->
    <div class="premium-nav-glass" data-aos="fade-up" data-aos-delay="50">
        <button class="nav-glass-btn active" onclick="switchTab('tab-overview', this)">
            <i class="bi bi-cpu"></i> Vue Stratégique
        </button>
        <button class="nav-glass-btn" onclick="switchTab('tab-management', this)">
            <i class="bi bi-gear-wide-connected"></i> Opérations
        </button>
        <button class="nav-glass-btn" onclick="switchTab('tab-distribution', this)">
            <i class="bi bi-diagram-3"></i> Distribution
        </button>
    </div>

    <div class="glass-tabs-content">
        <!-- TAB 1: OVERVIEW & ANALYTICS -->
        <div id="tab-overview" class="tab-pane active">
            <!-- Summary Metric Cards -->
            <div class="row g-4" data-aos="fade-up">
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="premium-card-glass p-4 border-top-primary">
                        <div class="glass-metric-icon bg-primary-light text-primary"><i class="bi bi-box-seam"></i></div>
                        <div class="h3 fw-850 mb-1">{{ campagne.stockInitial }}</div>
                        <div class="font-xs text-muted fw-bold text-uppercase ls-wide">Capacité Hub</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="premium-card-glass p-4 border-top-success">
                        <div class="glass-metric-icon bg-success-light text-success"><i class="bi bi-lightning-charge"></i></div>
                        <div class="h3 fw-850 mb-1 text-success">{{ campagne.moutonsVendus }}</div>
                        <div class="font-xs text-muted fw-bold text-uppercase ls-wide">Ventes Validées</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="premium-card-glass p-4 border-top-danger">
                        <div class="glass-metric-icon bg-danger-light text-danger"><i class="bi bi-wallet2"></i></div>
                        <div class="h3 fw-850 mb-1 text-danger">-{{ (campagne.totalDepenses/1000)|number_format(1) }}k</div>
                        <div class="font-xs text-muted fw-bold text-uppercase ls-wide">Frais Annexes</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="premium-card-glass p-4 border-top-accent">
                        <div class="glass-metric-icon bg-info-light text-info"><i class="bi bi-pin-map"></i></div>
                        <div class="h3 fw-850 mb-1 text-info">{{ campagne.marches|length }}</div>
                        <div class="font-xs text-muted fw-bold text-uppercase ls-wide">Canaux Déployés</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 2: MANAGEMENT (LOTS & COSTS) -->
        <div id="tab-management" class="tab-pane">
            <div class="row g-4">
                <div class="col-xl-8">
                    <div class="premium-card-glass">
                        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-light-subtle">
                            <div>
                                <h5 class="m-0 fw-800">Gestion des Flux (Lots)</h5>
                                <p class="text-muted font-xs m-0 text-uppercase fw-bold ls-tight">Détails d'acquisition</p>
                            </div>
                            <button class="btn btn-premium-add rounded-pill px-4" data-bs-toggle="collapse" data-bs-target="#addLotForm">
                                <i class="bi bi-plus-circle me-1"></i> Nouveau Lot
                            </button>
                        </div>
                        
                        <div class="collapse p-4 border-bottom" id="addLotForm">
                            {{ form_start(lotForm) }}
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="label-modern">Quantité</label>
                                        {{ form_widget(lotForm.quantite, {'attr': {'class': 'form-control rounded-3'}}) }}
                                    </div>
                                    <div class="col-md-4">
                                        <label class="label-modern">Âge (Mois)</label>
                                        {{ form_widget(lotForm.ageMois, {'attr': {'class': 'form-control rounded-3'}}) }}
                                    </div>
                                    <div class="col-md-4">
                                        <label class="label-modern">Coût Unitaire</label>
                                        {{ form_widget(lotForm.prixUnitaire, {'attr': {'class': 'form-control rounded-3'}}) }}
                                    </div>
                                </div>
                                <button class="btn-premium-add w-100 mt-4 py-2 rounded-3 shadow-lg">Enregistrer le Lot</button>
                            {{ form_end(lotForm) }}
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="bg-light-subtle">
                                    <tr>
                                        <th class="ps-4 py-3 font-xs text-uppercase fw-800 text-muted">ID</th>
                                        <th class="py-3 font-xs text-uppercase fw-800 text-muted">Volume</th>
                                        <th class="py-3 font-xs text-uppercase fw-800 text-muted">Prix Achat</th>
                                        <th class="py-3 font-xs text-uppercase fw-800 text-muted">Investissement Total</th>
                                        <th class="text-end pe-4"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for lot in campagne.lots %}
                                        <tr>
                                            <td class="ps-4 text-primary fw-800">#{{ lot.id }}</td>
                                            <td><span class="badge bg-primary-light text-primary rounded-pill px-3">{{ lot.quantite }} Moutons</span></td>
                                            <td class="fw-bold">{{ lot.prixUnitaire|number_format(0) }} <small class="text-muted">TND</small></td>
                                            <td class="h6 fw-800">{{ (lot.quantite * lot.prixUnitaire)|number_format(0, ',', ' ') }} <small class="font-xs">TND</small></td>
                                            <td class="text-end pe-4">
                                                <a href="{{ path('aid_lot_delete', {campagneId: campagne.id, id: lot.id}) }}" class="btn btn-icon btn-sm text-danger opacity-25 hover-opacity-100" onclick="return confirm('?')">
                                                    <i class="bi bi-trash3-fill"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-xl-4">
                    <div class="premium-card-glass">
                        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-light-subtle">
                            <h5 class="m-0 fw-800">Journal des Frais</h5>
                            <span class="badge bg-danger text-white rounded-pill">{{ campagne.depenses|length }} items</span>
                        </div>
                        
                        <div class="p-4 border-bottom">
                            {{ form_start(depenseForm) }}
                                <div class="mb-3">
                                    {{ form_widget(depenseForm.libelle, {'attr': {'class': 'form-control', 'placeholder': 'Libellé de la dépense...'}}) }}
                                </div>
                                <div class="row g-2">
                                    <div class="col-7">{{ form_widget(depenseForm.montant, {'attr': {'class': 'form-control', 'placeholder': 'Montant'}}) }}</div>
                                    <div class="col-5">{{ form_widget(depenseForm.date, {'attr': {'class': 'form-control'}}) }}</div>
                                </div>
                                <button class="btn btn-dark w-100 mt-3 rounded-pill fw-bold">Ajouter au journal</button>
                            {{ form_end(depenseForm) }}
                        </div>

                        <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                            {% for depense in campagne.depenses %}
                                <div class="list-group-item bg-transparent px-4 py-3 d-flex justify-content-between align-items-center border-0 border-bottom border-light">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-danger-light text-danger d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                            <i class="bi bi-tag-fill" style="font-size: 10px;"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold font-sm text-dark">{{ depense.libelle }}</div>
                                            <div class="font-xs text-muted">{{ depense.date ? depense.date|date('d/m/Y') : '-' }}</div>
                                        </div>
                                    </div>
                                    <div class="text-danger fw-850">-{{ depense.montant|number_format(0) }}</div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 3: DISTRIBUTION -->
        <div id="tab-distribution" class="tab-pane">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-850 m-0 ls-tight mb-2" style="color: #0D1426 !important;">Hub de Distribution</h3>
                    <p class="text-muted m-0 fw-bold font-xs text-uppercase ls-wide">Suivi des performances par canal</p>
                </div>
                <a href="{{ path('aid_marche_new', {campagneId: campagne.id}) }}" class="btn btn-premium-add px-4 rounded-pill">
                    <i class="bi bi-plus-lg me-1"></i> Nouveau Canal de Vente
                </a>
            </div>

            <div class="row g-4">
                {% for marche in campagne.marches %}
                    {% set marketPercent = marche.moutonsAmenes > 0 ? (marche.moutonsVendus / marche.moutonsAmenes * 100) : 0 %}
                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                        <div class="premium-card-glass p-4 h-100 transition-all {{ marche.id == leaderId ? 'market-leader-glow' : 'border-top-accent' }}">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h6 class="m-0 fw-bold d-flex align-items-center gap-2">
                                    <span class="pulse-status {{ marketPercent > 80 ? 'bg-success' : (marketPercent > 50 ? 'bg-info' : 'bg-warning') }}"></span>
                                    {{ marche.nom }}
                                </h6>
                                <div class="dropdown">
                                    <button class="btn btn-icon btn-sm bg-light rounded-circle" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                                    <ul class="dropdown-menu border-0 shadow-lg p-2 rounded-4">
                                        <li><a class="dropdown-item rounded-3" href="{{ path('aid_marche_show', {campagneId: campagne.id, id: marche.id}) }}"><i class="bi bi-eye me-2 text-primary"></i> Voir Rapport</a></li>
                                        <li><a class="dropdown-item rounded-3" href="{{ path('aid_marche_pdf', {campagneId: campagne.id, id: marche.id}) }}" target="_blank"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i> Télécharger PDF</a></li>
                                    </ul>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mb-4 mt-3">
                                <div class="p-3 bg-light rounded-3 text-center flex-grow-1 me-2">
                                    <div class="font-xs text-muted mb-1 uppercase fw-bold">Liquidation</div>
                                    <div class="h5 m-0 fw-850">{{ marketPercent|round }}%</div>
                                </div>
                                <div class="p-3 bg-success-light rounded-4 text-center flex-grow-1">
                                    <div class="font-xs text-success-dark mb-1 uppercase fw-bold">Impact Net</div>
                                    <div class="h5 m-0 fw-850 text-success">{{ (marche.totalNet/1000)|number_format(1) }}k</div>
                                </div>
                            </div>

                            <div class="mb-2 d-flex justify-content-between align-items-center">
                                <span class="font-xs fw-bold text-muted">Stock Ecoulé</span>
                                <span class="font-xs fw-850 text-primary">{{ marche.moutonsVendus }} / {{ marche.moutonsAmenes }}</span>
                            </div>
                            <div class="progress mb-4" style="height: 6px; border-radius: 10px; background: #eaedf2;">
                                <div class="progress-bar {{ marketPercent > 80 ? 'bg-success' : 'bg-primary' }}" style="width: {{ marketPercent }}%"></div>
                            </div>

                            <div class="mt-auto pt-3 border-top d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-bold" style="width: 24px; height: 24px; font-size: 8px;">
                                        {{ (marche.responsable ?: '??')|slice(0, 2)|upper }}
                                    </div>
                                    <span class="font-xs text-muted fw-bold">{{ marche.responsable ?: 'Non assigné' }}</span>
                                </div>
                                <span class="badge bg-light text-dark rounded-pill font-xs px-2">{{ marche.date ? marche.date|date('d M') : '-' }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<button class="action-drawer-btn" title="Actions Rapides" onclick="switchTab('tab-management', null)">
    <i class="bi bi-lightning-charge-fill"></i>
</button>

<script>
    function switchTab(tabId, btn) {
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-glass-btn').forEach(b => b.classList.remove('active'));
        
        document.getElementById(tabId).classList.add('active');
        if (btn) btn.classList.add('active');
        
        window.dispatchEvent(new Event('resize')); 
    }
</script>
{% endblock %}
