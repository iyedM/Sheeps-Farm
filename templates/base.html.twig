<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}FermeApp{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/datatables.net-bs5@1.13.8/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body>
{% if app.user %}
    {% set current = app.request.attributes.get('_route') %}
    {% set fullname = app.user.fullName|default(app.user.userIdentifier) %}
    {% set initialA = (app.user.prenom|default('U')|slice(0,1)|upper) %}
    {% set initialB = (app.user.nom|default('')|slice(0,1)|upper) %}
    {% set initials = initialA ~ initialB %}
    {% set role = app.user.roles|first %}
    <div class="app-shell">
        <div id="sidebarBackdrop" class="sidebar-backdrop"></div>

        <aside id="appSidebar" class="app-sidebar">
            <div class="sidebar-logo">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M14 18C14 12.477 18.477 8 24 8C29.523 8 34 12.477 34 18C34 19.205 33.787 20.361 33.396 21.432C36.148 22.283 38 24.848 38 27.75C38 31.478 34.866 34.5 31 34.5H19C14.582 34.5 11 31.142 11 27C11 23.635 13.362 20.785 16.679 19.894C15.619 19.378 14.778 18.44 14.333 17.286" fill="#ECF0F1"/>
                    <circle cx="18.5" cy="16.5" r="1.5" fill="#1B2A41"/>
                    <path d="M34.5 30.5C34.5 30.5 36 31.2 36 33C36 34.8 34.8 36 33 36" stroke="#ECF0F1" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="logo-text fw-semibold">FermeApp</span>
            </div>

            <div class="sidebar-label">Navigation</div>
            <nav class="sidebar-nav">
                <a class="nav-link {{ current == 'app_dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard') }}"><span class="nav-icon bi bi-grid-1x2-fill"></span><span class="nav-label">Dashboard</span></a>
                <a class="nav-link {{ current starts with 'app_mouton' ? 'active' : '' }}" href="{{ path('app_mouton_index') }}"><span class="nav-icon bi bi-emoji-dizzy"></span><span class="nav-label">Moutons</span></a>
                <a class="nav-link {{ current starts with 'app_grange' ? 'active' : '' }}" href="{{ path('app_grange_index') }}"><span class="nav-icon bi bi-building"></span><span class="nav-label">Granges</span></a>
                <a class="nav-link {{ current starts with 'app_depense' ? 'active' : '' }}" href="{{ path('app_depense_index') }}"><span class="nav-icon bi bi-cash-stack"></span><span class="nav-label">Dépenses</span></a>
                <a class="nav-link {{ current starts with 'app_commerce_achat' ? 'active' : '' }}" href="{{ path('app_commerce_achat_index') }}"><span class="nav-icon bi bi-bag-plus"></span><span class="nav-label">Achats</span></a>
                <a class="nav-link {{ current starts with 'app_commerce_vente' ? 'active' : '' }}" href="{{ path('app_commerce_vente_index') }}"><span class="nav-icon bi bi-bag-check"></span><span class="nav-label">Ventes</span></a>
                <a class="nav-link {{ current starts with 'app_facture_achat' ? 'active' : '' }}" href="{{ path('app_facture_achat_index') }}"><span class="nav-icon bi bi-file-earmark-arrow-down"></span><span class="nav-label">Factures Achat</span></a>
                <a class="nav-link {{ current starts with 'app_facture_vente' ? 'active' : '' }}" href="{{ path('app_facture_vente_index') }}"><span class="nav-icon bi bi-file-earmark-arrow-up"></span><span class="nav-label">Factures Vente</span></a>
            </nav>

            <div class="sidebar-user-card">
                <div class="sidebar-user-inner">
                    <span class="avatar">{{ initials }}</span>
                    <div>
                        <div class="text-white fw-semibold" style="line-height:1.2">{{ fullname }}</div>
                        <span class="role-chip {{ role == 'ROLE_ADMIN' ? 'admin' : 'user' }}">{{ role == 'ROLE_ADMIN' ? 'Admin' : 'Utilisateur' }}</span>
                    </div>
                </div>
            </div>
        </aside>

        <div class="app-main">
            <header class="topbar">
                <div class="d-flex align-items-center gap-2">
                    <button id="sidebarToggle" class="icon-btn d-md-none" type="button" aria-label="Menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <h5 class="mb-0">{% block page_title %}FermeApp{% endblock %}</h5>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="icon-btn position-relative" type="button" aria-label="Notifications">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger rounded-circle"></span>
                    </button>

                    <div class="dropdown">
                        <button class="btn btn-light border d-flex align-items-center gap-2" data-bs-toggle="dropdown" type="button">
                            <span class="avatar">{{ initials }}</span>
                            <span class="d-none d-sm-inline">{{ fullname }}</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-sm border-0 p-2" style="min-width: 240px; border-radius: 12px;">
                            <div class="px-2 pb-2 border-bottom mb-2">
                                <div class="fw-semibold">{{ fullname }}</div>
                                <span class="role-chip {{ role == 'ROLE_ADMIN' ? 'admin' : 'user' }}">{{ role == 'ROLE_ADMIN' ? 'ROLE_ADMIN' : 'ROLE_USER' }}</span>
                            </div>
                            <a class="dropdown-item text-danger rounded" href="{{ path('app_logout') }}">
                                <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                            </a>
                        </div>
                    </div>
                </div>
            </header>

            <main class="main-content">
                {% block body %}{% endblock %}
            </main>
        </div>
    </div>
{% else %}
    {% block guest_body %}{% endblock %}
{% endif %}

<div class="toast-stack">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            {% set tone = label in ['error', 'danger'] ? 'error' : (label == 'warning' ? 'warning' : (label == 'info' ? 'info' : 'success')) %}
            <div class="app-toast {{ tone }}">
                <div class="d-flex align-items-start gap-2">
                    <div>
                        {% if tone == 'success' %}<i class="bi bi-check-circle-fill text-success"></i>{% endif %}
                        {% if tone == 'error' %}<i class="bi bi-x-circle-fill text-danger"></i>{% endif %}
                        {% if tone == 'warning' %}<i class="bi bi-exclamation-triangle-fill" style="color: var(--warning)"></i>{% endif %}
                        {% if tone == 'info' %}<i class="bi bi-info-circle-fill text-info"></i>{% endif %}
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold" style="font-size:13px">
                            {% if tone == 'success' %}Succès{% endif %}
                            {% if tone == 'error' %}Erreur{% endif %}
                            {% if tone == 'warning' %}Attention{% endif %}
                            {% if tone == 'info' %}Information{% endif %}
                        </div>
                        <div style="font-size:12px; color: var(--text-secondary)">{{ message }}</div>
                    </div>
                    <button type="button" class="btn-close btn-sm" onclick="this.closest('.app-toast').remove()"></button>
                </div>
                <div class="toast-progress"></div>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/datatables.net@1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/datatables.net-bs5@1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
{% endblock %}
</body>
</html>
