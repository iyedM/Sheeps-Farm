<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FermeApp - Tableau de Bord{% endblock %}</title>
    
    {# ── Font: Inter ── #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    {# ── Bootstrap 5.3 (Grid Base Only) ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {# ── Bootstrap Icons 1.11 ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    {# ── DataTables CSS ── #}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    
    {# ── Select2 CSS ── #}
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    
    {# ── Flatpickr CSS ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    
    {# ── SweetAlert2 CSS ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.min.css">
    
    {# ── AOS CSS ── #}
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    {# ── Custom CSS ── #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body>
    <div class="app-shell">
        
        {# ── Sidebar ── #}
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 12c-1.1-1.3-2.6-2-4.1-2h-1V8.6c1.3-.4 2.3-1.6 2.3-3.1 0-1.8-1.4-3.2-3.2-3.2-1.4 0-2.6.9-3.1 2.2-.4-1.3-1.6-2.2-3.1-2.2C5.1 2.3 3.6 3.7 3.6 5.5c0 1.5.9 2.7 2.3 3.1V10h-1C3.3 10 1.9 10.7.8 12c-.5.6-.8 1.4-.8 2.2V19c0 1.7 1.3 3 3 3h16c1.7 0 3-1.3 3-3v-4.8c0-.8-.3-1.6-.8-2.2zM5.6 5.5c0-.7.6-1.2 1.2-1.2s1.2.6 1.2 1.2-.6 1.2-1.2 1.2-1.2-.6-1.2-1.2zm8.8 0c0-.7.6-1.2 1.2-1.2s1.2.6 1.2 1.2-.6 1.2-1.2 1.2-1.2-.6-1.2-1.2zM3 20c-.6 0-1-.4-1-1v-4.8c0-.4.2-.8.4-1 .8-.8 1.9-1.2 2.6-1.2h2v7H3zm16-1c0 .6-.4 1-1 1H9v-7h10c.8 0 1.8.4 2.6 1.2.3.2.4.6.4 1V19z"/>
                    </svg>
                </div>
                <div class="sidebar-logo-text">
                    <span class="app-name">FermeApp</span>
                    <span class="app-env">Production</span>
                </div>
                <button class="sidebar-collapse-btn" title="Réduire">
                    <i class="bi bi-layout-sidebar"></i>
                </button>
            </div>
            
            <div class="sidebar-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Rechercher..." />
                <kbd>⌘K</kbd>
            </div>
            
            <nav class="sidebar-nav">
                <div class="nav-section-label">Principal</div>
                
                <a href="{{ path('app_dashboard') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                    <span class="nav-item-label">Dashboard</span>
                </a>
                
                <a href="{{ path('app_mouton_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-clipboard-heart"></i></span>
                    <span class="nav-item-label">Moutons</span>
                    <span class="nav-item-badge">247</span>
                </a>
                
                <a href="{{ path('app_grange_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-building-fill"></i></span>
                    <span class="nav-item-label">Granges</span>
                </a>
                
                <div class="nav-section-label">Finance & Opérations</div>
                
                <a href="{{ path('app_depense_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-cash-coin"></i></span>
                    <span class="nav-item-label">Dépenses</span>
                </a>
                
                <a href="{{ path('app_commerce_achat_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-bag-plus-fill"></i></span>
                    <span class="nav-item-label">Achats</span>
                </a>
                
                <a href="{{ path('app_commerce_vente_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-bag-check-fill"></i></span>
                    <span class="nav-item-label">Ventes</span>
                </a>
                
                <a href="{{ path('app_facture_achat_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-file-earmark-arrow-down-fill"></i></span>
                    <span class="nav-item-label">Factures Achat</span>
                </a>
                
                <a href="{{ path('app_facture_vente_index') }}" class="nav-item">
                    <span class="nav-item-icon"><i class="bi bi-file-earmark-arrow-up-fill"></i></span>
                    <span class="nav-item-label">Factures Vente</span>
                </a>
            </nav>
            
            <div class="sidebar-user">
                <div class="sidebar-user-card" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="sidebar-user-avatar">
                        {% if app.user %}{{ app.user.userIdentifier|slice(0, 2)|upper }}{% else %}AA{% endif %}
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name">{% if app.user %}{{ app.user.userIdentifier|split('@')|first|capitalize }}{% else %}Ahmed Administrateur{% endif %}</span>
                        <span class="sidebar-user-role">Administrateur</span>
                    </div>
                    <div class="sidebar-user-status"></div>
                </div>
            </div>
        </aside>

        {# ── Main Wrapper ── #}
        <div class="main-wrapper">
            
            {# ── Topbar ── #}
            <header class="topbar">
                <button class="topbar-mobile-toggle">
                    <i class="bi bi-list"></i>
                </button>
                
                <nav class="topbar-breadcrumb">
                    <span class="bc-parent">FermeApp</span>
                    <i class="bi bi-chevron-right bc-sep"></i>
                    <span class="bc-current">{% block breadcrumb_current %}Dashboard{% endblock %}</span>
                </nav>
                
                <div class="topbar-right">
                    <button class="topbar-btn" title="Recherche globale">
                        <i class="bi bi-search"></i>
                    </button>
                    
                    <button class="topbar-btn" title="Notifications">
                        <i class="bi bi-bell"></i>
                        <span class="notification-badge"></span>
                    </button>
                    
                    <button class="topbar-btn theme-toggle" title="Thème">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>
                    
                    <div class="topbar-divider"></div>
                    
                    <div class="topbar-user dropdown">
                        <div class="topbar-user-info text-end d-none d-sm-flex" data-bs-toggle="dropdown">
                            <span class="topbar-user-name">{% if app.user %}{{ app.user.userIdentifier|split('@')|first|capitalize }}{% else %}Ahmed{% endif %}</span>
                            <span class="role-badge role-admin">Admin</span>
                        </div>
                        <div class="topbar-avatar" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            {% if app.user %}{{ app.user.userIdentifier|slice(0, 2)|upper }}{% else %}AM{% endif %}
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person"></i> Profil</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear"></i> Paramètres</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i> Déconnexion</a></li>
                        </ul>
                        <i class="bi bi-chevron-down" style="font-size:11px;color:var(--text-muted); cursor: pointer;" data-bs-toggle="dropdown"></i>
                    </div>
                </div>
            </header>

            {# ── Page Content ── #}
            <main class="page-content">
                {% block body %}{% endblock %}
            </main>
            
        </div>
    </div>

    {# ── Flash Toasts Container ── #}
    <div id="toast-container">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="app-toast toast-{{ label == 'danger' ? 'error' : label }}" data-auto-dismiss="4000">
                    <div class="toast-icon-wrap">
                        {% if label == 'success' %}<i class="bi bi-check-circle-fill"></i>
                        {% elseif label == 'danger' or label == 'error' %}<i class="bi bi-exclamation-octagon-fill"></i>
                        {% elseif label == 'warning' %}<i class="bi bi-exclamation-triangle-fill"></i>
                        {% else %}<i class="bi bi-info-circle-fill"></i>{% endif %}
                    </div>
                    <div class="toast-body">
                        <div class="toast-title">
                            {% if label == 'success' %}Succès
                            {% elseif label == 'danger' or label == 'error' %}Erreur
                            {% elseif label == 'warning' %}Attention
                            {% else %}Information{% endif %}
                        </div>
                        <div class="toast-message">{{ message }}</div>
                    </div>
                    <button class="toast-close"><i class="bi bi-x"></i></button>
                    <div class="toast-progress"></div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# ── Scripts ── #}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.css"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.6/dist/sweetalert2.all.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/countup.js/2.8.0/countUp.umd.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>
