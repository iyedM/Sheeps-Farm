{% extends 'base.html.twig' %}

{% block title %}Dépenses - FermeApp{% endblock %}
{% block breadcrumb_current %}Dépenses{% endblock %}

{% block body %}
<div class="page-header" data-aos="fade-down">
    <div>
        <h1 class="page-title">Dépenses</h1>
        <p class="page-subtitle">Suivi des coûts et des charges</p>
    </div>
    <div class="page-actions">
        <a href="{{ path('app_depense_new') }}" class="btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle dépense
        </a>
    </div>
</div>

<div class="row g-3 mb-4" data-aos="fade-down" data-aos-delay="100">
    <div class="col-md-6 col-lg-4">
        <div class="stat-card" style="box-shadow: none; border: 1px solid var(--card-border);">
            <div class="stat-icon" style="--icon-bg: rgba(255, 71, 87, 0.1); --icon-color: #ff4757;">
                <i class="bi bi-graph-down-arrow"></i>
            </div>
            <div class="stat-info">
                <h3>Total Dépensé</h3>
                <div class="stat-value">{{ total|number_format(2, '.', ' ') }} <span style="font-size:14px; color:var(--text-muted);">TND</span></div>
            </div>
        </div>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="200">
    <div class="table-card-header">
        <div>
            <h3>Historique des Dépenses</h3>
            <span class="record-count">{{ pagination.getTotalItemCount() }} résultats</span>
        </div>
        <div class="table-actions">
            <div class="search-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Rechercher (page)..." class="table-search" id="tableSearch"/>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table dt-table dt-server" width="100%">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Montant</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for d in pagination %}
                <tr>
                    <td><span class="badge-status" style="background: var(--bg-hover); color: var(--text-secondary); border-radius: var(--radius-sm);"><i class="bi bi-calendar3 me-1"></i> {{ d.date|date('d/m/Y') }}</span></td>
                    <td style="font-weight: 500;">{{ d.description }}</td>
                    <td><strong style="color: var(--danger);">{{ d.montant|number_format(2, '.', ' ') }}</strong> <span style="font-size:12px; color:var(--text-muted);">TND</span></td>
                    <td class="text-end">
                        <div class="row-actions justify-content-end">
                            <a href="{{ path('app_depense_edit', {id:d.id}) }}" class="action-btn action-edit" title="Modifier">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form method="post" action="{{ path('app_depense_delete', {id:d.id}) }}" class="d-inline" id="form-delete-depense-{{ d.id }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_depense_' ~ d.id) }}">
                                <button type="button" class="action-btn action-delete" title="Supprimer" onclick="confirmDelete('form-delete-depense-{{ d.id }}', 'cette dépense')">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">Aucune dépense trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div class="table-pagination-wrapper">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>
{% endblock %}
