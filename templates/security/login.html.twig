<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - FermeApp</title>
    
    {# ── Font: Inter ── #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    {# ── Bootstrap 5.3 ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {# ── Bootstrap Icons ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    {# ── AOS CSS ── #}
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    {# ── Custom CSS ── #}
    {{ encore_entry_link_tags('app') }}
</head>
<body>
    <div class="auth-shell">
        <div class="auth-left">
            <div class="auth-brand" data-aos="fade-down">
                <div class="auth-logo">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 12c-1.1-1.3-2.6-2-4.1-2h-1V8.6c1.3-.4 2.3-1.6 2.3-3.1 0-1.8-1.4-3.2-3.2-3.2-1.4 0-2.6.9-3.1 2.2-.4-1.3-1.6-2.2-3.1-2.2C5.1 2.3 3.6 3.7 3.6 5.5c0 1.5.9 2.7 2.3 3.1V10h-1C3.3 10 1.9 10.7.8 12c-.5.6-.8 1.4-.8 2.2V19c0 1.7 1.3 3 3 3h16c1.7 0 3-1.3 3-3v-4.8c0-.8-.3-1.6-.8-2.2zM5.6 5.5c0-.7.6-1.2 1.2-1.2s1.2.6 1.2 1.2-.6 1.2-1.2 1.2-1.2-.6-1.2-1.2zm8.8 0c0-.7.6-1.2 1.2-1.2s1.2.6 1.2 1.2-.6 1.2-1.2 1.2-1.2-.6-1.2-1.2zM3 20c-.6 0-1-.4-1-1v-4.8c0-.4.2-.8.4-1 .8-.8 1.9-1.2 2.6-1.2h2v7H3zm16-1c0 .6-.4 1-1 1H9v-7h10c.8 0 1.8.4 2.6 1.2.3.2.4.6.4 1V19z"/>
                    </svg>
                </div>
                <h1 class="auth-app-name">FermeApp</h1>
            </div>
            
            <div class="auth-hero-text" data-aos="fade-right" data-aos-delay="100">
                <h2>Gérez votre ferme<br>avec intelligence.</h2>
                <p>Suivi des moutons, granges, ventes et achats — tout en un.</p>
            </div>
            
            <div class="auth-stats" data-aos="fade-up" data-aos-delay="200">
                <span class="auth-stat-pill"><i class="bi bi-clipboard-data"></i> 25 Moutons</span>
                <span class="auth-stat-pill"><i class="bi bi-building"></i> 3 Granges</span>
                <span class="auth-stat-pill"><i class="bi bi-shield-check"></i> 100% Secure</span>
            </div>
        </div>
        
        <div class="auth-right">
            <div class="auth-card" data-aos="fade-left" data-aos-delay="150">
                <h2 class="auth-title">Connexion</h2>
                <p class="auth-sub">Bienvenue sur FermeApp</p>
                
                <form method="post">
                    {% if error %}
                        <div class="alert alert-danger" style="font-size:13px; border-radius:var(--radius-sm); border:none; background:var(--danger-light); color:var(--danger);">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info" style="font-size:13px; border-radius:var(--radius-sm); border:none; background:var(--info-light); color:var(--info);">
                            Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="#">se déconnecter</a>
                        </div>
                    {% endif %}

                    <div class="form-floating mb-3">
                        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus placeholder="name@example.com">
                        <label for="inputEmail">Adresse email</label>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required placeholder="Mot de passe">
                        <label for="inputPassword">Mot de passe</label>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="checkbox mb-4 d-flex justify-content-between align-items-center">
                        <label style="font-size:13px; color:var(--text-muted); display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" name="_remember_me" style="accent-color:var(--accent); width:16px; height:16px;"> Se souvenir de moi
                        </label>
                        <a href="#" style="font-size:13px; color:var(--accent); font-weight:600; text-decoration:none;">Mot de passe oublié ?</a>
                    </div>

                    <button class="btn-primary btn-lg w-100 btn-submit" type="submit">
                        <span class="btn-text">Se connecter</span>
                        <div class="btn-spinner spinner-border text-light d-none" role="status" style="width: 16px; height: 16px;"></div>
                    </button>
                    
                    <div style="margin-top: 24px; text-align: center; font-size: 13px; color: var(--text-muted);">
                        Pas encore de compte ? <a href="#" style="color: var(--accent); font-weight: 600; text-decoration: none;">Créer un compte</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# ── Scripts ── #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    {{ encore_entry_script_tags('app') }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof AOS !== 'undefined') AOS.init({ duration: 400, once: true });
            
            const form = document.querySelector('form');
            if(form) {
                form.addEventListener('submit', function() {
                    if(this.checkValidity()) {
                        const btn = this.querySelector('.btn-submit');
                        btn.classList.add('loading');
                        btn.style.pointerEvents = 'none';
                    }
                });
            }
        });
    </script>
</body>
</html>
