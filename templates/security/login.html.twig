<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Connexion | FermeApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    {{ encore_entry_link_tags('app') }}
</head>
<body>
<div class="min-vh-100 d-flex">
    <section class="d-none d-md-flex flex-column justify-content-center px-5" style="width:50%; background:#1B2A41; color:#fff;">
        <div style="max-width:420px">
            <svg viewBox="0 0 120 120" width="120" height="120" fill="none" xmlns="http://www.w3.org/2000/svg" class="mb-4">
                <path d="M35 60c0-14 11-25 25-25s25 11 25 25-11 25-25 25H45c-11 0-20-9-20-20 0-8 5-15 12-18" fill="#ECF0F1"/>
                <circle cx="48" cy="56" r="3" fill="#1B2A41"/>
            </svg>
            <h1 style="font-size:32px; font-weight:600">FermeApp</h1>
            <p style="color:#B8C5D6">Pilotez votre exploitation ovine avec une interface claire, moderne et orientée performance.</p>
        </div>
    </section>

    <section class="d-flex align-items-center justify-content-center px-4" style="width:100%; background:#fff;">
        <div style="width:100%; max-width:420px;">
            <h2 class="mb-1" style="font-weight:600; letter-spacing:-.02em">Connexion</h2>
            <p class="text-secondary mb-4">Bienvenue sur votre espace FermeApp.</p>

            {% if error %}
                <div class="alert alert-danger py-2">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form method="post">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-3">
                    <label class="form-label small text-muted">Email</label>
                    <input type="email" name="email" class="form-control border-0 border-bottom rounded-0 px-0" value="{{ last_username }}" required autofocus>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted">Mot de passe</label>
                    <input type="password" name="password" class="form-control border-0 border-bottom rounded-0 px-0" required>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2" style="height:48px;">Se connecter</button>
            </form>

            <p class="text-center mt-3 mb-0 text-secondary">
                Pas de compte ?
                <a href="{{ path('app_register') }}" style="color:var(--accent); font-weight:600;">Créer un compte</a>
            </p>
        </div>
    </section>
</div>
{{ encore_entry_script_tags('app') }}
</body>
</html>
